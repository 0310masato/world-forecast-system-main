# =========================================================================
# Maritime & Energy Sentinel - Environment Variables Example
# =========================================================================
#
# Copy this file to '.env' or '.env.local' in the project root.
# Do NOT commit files containing actual API keys to git.

# -------------------------------------------------------------------------
# 1. Mock Control Flags (Phase 1 Default)
# -------------------------------------------------------------------------
# Set to 'true' to force simulated mock engines for vessels, weather, 
# and news. Highly recommended for offline demonstration and testing.
# If keys are missing, the system automatically falls back to mock mode.
HORMUZ_USE_MOCK=true
HORMUZ_NEWS_USE_MOCK=true

# -------------------------------------------------------------------------
# 2. External Provider Keys (Optional / Phase 2+)
# -------------------------------------------------------------------------
# AISStream API Key (for real-time AIS vessel coordinates tracking)
# AISSTREAM_API_KEY=your_aisstream_api_key_here

# News API Key (for real-world geopolitical feed fetching)
# NEWS_API_KEY=your_news_api_key_here

# Gemini API Key (for advanced AI news interpretation and risk deduction)
# GEMINI_API_KEY=your_gemini_api_key_here
